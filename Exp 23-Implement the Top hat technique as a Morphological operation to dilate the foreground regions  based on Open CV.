import cv2
import numpy as np

# Read the image
image = cv2.imread(r"C:\Users\nagin\Downloads\oip 9.jpg")

# Reduce image size to 15%
image = cv2.resize(image, None, fx=0.15, fy=0.15)

# Convert image to grayscale
gray_image = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)

# Create kernel
kernel = np.ones((5,5), np.uint8)

# Apply Top Hat Morphological Operation
top_hat_image = cv2.morphologyEx(gray_image, cv2.MORPH_TOPHAT, kernel)

# Display images
cv2.imshow('Original Image', image)
cv2.imshow('Top Hat Image', top_hat_image)

cv2.waitKey(0)
cv2.destroyAllWindows()
