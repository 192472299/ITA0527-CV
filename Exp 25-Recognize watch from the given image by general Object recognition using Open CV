import cv2

# Load cascade file with full path
watch_cascade = cv2.CascadeClassifier(r"C:\Users\nagin\Downloads\watch_cascade.xml")

# Read image
image = cv2.imread(r"C:\Users\nagin\Downloads\oip 18.jpg")

# Convert to grayscale
gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)

# Detect watch
watches = watch_cascade.detectMultiScale(gray, scaleFactor=1.1, minNeighbors=5, minSize=(30,30))

# Draw rectangle
for (x,y,w,h) in watches:
    cv2.rectangle(image,(x,y),(x+w,y+h),(0,255,0),2)

cv2.imshow("Detected Watch",image)
cv2.waitKey(0)
cv2.destroyAllWindows()
