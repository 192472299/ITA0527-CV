import numpy as np
import cv2

def create_circle_image(image_size):

    height, width = image_size

    # Create white image
    image = np.ones((height, width, 3), dtype=np.uint8) * 255

    # Circle properties
    center = (width // 2, height // 2)
    radius = min(width, height) // 4

    # Draw circle (Red)
    cv2.circle(image, center, radius, (0, 0, 255), 2)

    # Save image to same path
    cv2.imwrite(r"C:\Users\nagin\Downloads\OIP (1).jpg", image)

    # Display image
    cv2.imshow("Circle Image", image)
    cv2.waitKey(0)
    cv2.destroyAllWindows()


# Example usage
user_width = int(input("Enter image width: "))
user_height = int(input("Enter image height: "))

create_circle_image((user_height, user_width))
