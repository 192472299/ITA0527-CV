import cv2

def play_video_reverse_slow(video_path):

    cap = cv2.VideoCapture(video_path)
    frames = []

    # Read all frames
    while cap.isOpened():
        ret, frame = cap.read()
        if not ret:
            break
        frames.append(frame)

    cap.release()

    # Play frames in reverse slow motion
    for frame in reversed(frames):
        cv2.imshow('Reverse Slow Motion Video', frame)

        if cv2.waitKey(100) & 0xFF == ord('q'):   # 100 ms delay
            break

    cv2.destroyAllWindows()


# Example usage
